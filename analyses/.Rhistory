Parameter == 'b_p_genderF' ~ 'Female (ref. Male)',
Parameter == 'b_prof_classLowStatus' ~ 'Low status (ref. High)',
Parameter == 'b_prof_classMidStatus' ~ 'Mid status (ref. High)',
Parameter == 'b_world_regionAfrica' ~ 'Africa (ref. Native)',
Parameter == 'b_world_regionAsia' ~ 'Asia (ref. Native)',
Parameter == 'b_world_regionSouthAmerica' ~ 'South America (ref. Native)',
)) %>%
mutate(Group = case_when(
Parameter %in% c('Intercept 1', 'Intercept 2', 'Intercept 3') ~ 'Intercepts',
Parameter %in% c('Age (decades)') ~ 'Age',
Parameter %in% c('Conservative statement (ref. Progressive)') ~ 'Statement orientation',
Parameter %in% c('Female (ref. Male)') ~ 'Gender',
Parameter %in% c('Low status (ref. High)', 'Mid status (ref. High)') ~ 'Professional status',
Parameter %in% c('Africa (ref. Native)', 'Asia (ref. Native)', 'South America (ref. Native)') ~ 'World region'
)) %>%
ggplot(., aes(x=Median, y=factor(Parameter, levels=order), color=Group)) +
geom_vline(xintercept=0, linetype=2, color='gray') +
geom_errorbar(aes(xmin=CI_low, xmax=CI_high), height=0, width=.5, color='black')+
geom_point() +
theme_light() +
labs(x="", y="")+
theme(legend.position = 'none')
